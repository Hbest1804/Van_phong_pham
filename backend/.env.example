# Environment variables
PORT=5000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS – URL của frontend (khi deploy Docker: http://localhost)
FRONTEND_URL=http://localhost:3000

# Gemini AI API Key (Lấy tại Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key-here

# SMTP – Gửi email (dùng Gmail App Password hoặc SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# Thời gian hiệu lực link reset password (phút)
RESET_TOKEN_EXPIRES_MIN=15
